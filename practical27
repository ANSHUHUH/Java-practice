
import java.awt.*;
import java.awt.event.*;
public class Practical27 extends Frame implements ActionListener{
	
	Label l1,l2,l3;
	TextField t1,t2,t3;
	Button btn;
	Practical27(){
		l1 = new Label("name : ");
		l2 = new Label("emp no : ");
		l3 = new Label("salary : ");
		
		t1 = new TextField(15);
		t2 = new TextField(15);
		t3 = new TextField(15);
		
		btn = new Button("submit");
		btn.addActionListener(this);
		
		setLayout(new GridLayout(4,2));
		
		add(l1);
		add(t1);
		add(l2);
		add(t2);
		add(l3);
		add(t3);
		add(btn);
		
		setSize(400,300);
		
		setVisible(true);
		addWindowListener(new WindowAdapter() {
			public void windowClosing(WindowEvent we) {
				System.exit(0);
			}
		});
	}
public void actionPerformed(ActionEvent e) {
	
	String name = t1.getText();
	String empno = t2.getText();
	String salary = t3.getText();
	
	new displayframe(empno,name,salary);
  }
public static void main(String[] args) {
	new Practical27();
}
}
class displayframe extends Frame{
	 public displayframe(String emp,String nam,String sal){
		Label empno = new Label("empnumber : "+emp);
		Label name = new Label("name : "+nam);
		Label salary = new Label("salary : "+sal);
		
		setLayout(new GridLayout(3,1));
		
		add(empno);
		add(name);
		add(salary);
		
		setSize(400,200);
		setLocation(500,200);
		
		setVisible(true);
		addWindowListener(new WindowAdapter() {
			public void windowClosing(WindowEvent ae) {
				System.exit(0);
			}
		});
	}
}
