class Practical13 {
    String name;
    double salary;

    Practical13(String name, double salary) {
        this.name = name;
        this.salary = salary;
    }
    void work() {
        System.out.println(name + " is a general employee");
    }
    void getSalary() {
        System.out.println(name + " salary is: " + salary);
    }
}
class HRManager extends Employee {
    HRManager(String name, double salary) {
        super(name, salary);
    }
    @Override
    void work() {
        System.out.println(name + " is manage employee relations and HR tasks.");
    }
}
public class Main {
    public static void main(String[] args) {
        Practical13 emp = new Practical13("Rahul", 30000);
        emp.work();
        emp.getSalary();
        System.out.println();
        HRManager hr = new HRManager("Priya", 50000);
        hr.work();              
        hr.getSalary();         
        hr.manageEmployees();   
    }
}
